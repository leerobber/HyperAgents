# Sovereign Core — Local Model Configuration
# All LLM calls route to local Qwen2.5-32B-AWQ via litellm
# Ensure your local model server is running:
#   vllm serve Qwen/Qwen2.5-32B-AWQ --port 8001

OPENAI_API_KEY=not-needed
OPENAI_API_BASE=http://localhost:8001/v1

# If running inside Docker with --network=host, localhost works.
# If using Docker bridge network, use instead:
# OPENAI_API_BASE=http://host.docker.internal:8001/v1
